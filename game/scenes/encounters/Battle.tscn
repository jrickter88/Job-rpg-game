[gd_scene load_steps=3 format=3]

[ext_resource type="Script" path="res://src/Rpg.Game/Encounters/BattleController.cs" id="1_controller"]
[ext_resource type="Script" path="res://src/Rpg.Game/Encounters/BattleFormationView.cs" id="2_formation"]

[node name="Battle" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_controller")

[node name="Background" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
mouse_filter = 2
color = Color(0.055, 0.065, 0.095, 1)

[node name="Margin" type="MarginContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/margin_left = 60
theme_override_constants/margin_top = 12
theme_override_constants/margin_right = 60
theme_override_constants/margin_bottom = 12

[node name="VBox" type="VBoxContainer" parent="Margin"]
layout_mode = 2
theme_override_constants/separation = 5

[node name="Title" type="Label" parent="Margin/VBox"]
layout_mode = 2
text = "Milestone 3.14 — Playable Battle"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 25

[node name="Explanation" type="Label" parent="Margin/VBox"]
layout_mode = 2
text = "Choose Attack and a target. Core combat resolves both sides; this scene only presents the result."
horizontal_alignment = 1
autowrap_mode = 2
theme_override_colors/font_color = Color(0.72, 0.82, 1, 1)
theme_override_font_sizes/font_size = 14

[node name="EncounterId" type="Label" parent="Margin/VBox"]
layout_mode = 2
text = "Encounter loads here."
theme_override_font_sizes/font_size = 15

[node name="BattlefieldId" type="Label" parent="Margin/VBox"]
layout_mode = 2
text = "Battlefield loads here."
theme_override_font_sizes/font_size = 14

[node name="FormationView" type="Control" parent="Margin/VBox"]
custom_minimum_size = Vector2(900, 230)
layout_mode = 2
script = ExtResource("2_formation")

[node name="StatusRow" type="HBoxContainer" parent="Margin/VBox"]
custom_minimum_size = Vector2(0, 54)
layout_mode = 2
theme_override_constants/separation = 40

[node name="PartyStatus" type="VBoxContainer" parent="Margin/VBox/StatusRow"]
layout_mode = 2
size_flags_horizontal = 3

[node name="Heading" type="Label" parent="Margin/VBox/StatusRow/PartyStatus"]
layout_mode = 2
text = "PARTY HP"
theme_override_colors/font_color = Color(0.66, 0.82, 1, 1)
theme_override_font_sizes/font_size = 15

[node name="EnemyStatus" type="VBoxContainer" parent="Margin/VBox/StatusRow"]
layout_mode = 2
size_flags_horizontal = 3

[node name="Heading" type="Label" parent="Margin/VBox/StatusRow/EnemyStatus"]
layout_mode = 2
text = "ENEMY HP"
theme_override_colors/font_color = Color(1, 0.72, 0.72, 1)
theme_override_font_sizes/font_size = 15

[node name="CommandArea" type="VBoxContainer" parent="Margin/VBox"]
layout_mode = 2
theme_override_constants/separation = 3

[node name="Phase" type="Label" parent="Margin/VBox/CommandArea"]
layout_mode = 2
text = "Battle phase loads here."
horizontal_alignment = 1
theme_override_colors/font_color = Color(1, 0.83, 0.58, 1)
theme_override_font_sizes/font_size = 15

[node name="CommandRow" type="HBoxContainer" parent="Margin/VBox/CommandArea"]
layout_mode = 2
alignment = 1
theme_override_constants/separation = 10

[node name="Attack" type="Button" parent="Margin/VBox/CommandArea/CommandRow"]
custom_minimum_size = Vector2(130, 34)
layout_mode = 2
text = "Attack"

[node name="TargetPrompt" type="Label" parent="Margin/VBox/CommandArea/CommandRow"]
layout_mode = 2
text = "Target:"
vertical_alignment = 1

[node name="Targets" type="HBoxContainer" parent="Margin/VBox/CommandArea/CommandRow"]
layout_mode = 2
theme_override_constants/separation = 6

[node name="EventLog" type="RichTextLabel" parent="Margin/VBox"]
custom_minimum_size = Vector2(0, 100)
layout_mode = 2
size_flags_vertical = 3
scroll_following = true
theme_override_colors/default_color = Color(0.88, 0.9, 0.96, 1)
theme_override_font_sizes/normal_font_size = 14

[node name="ResultRow" type="HBoxContainer" parent="Margin/VBox"]
custom_minimum_size = Vector2(0, 34)
layout_mode = 2
alignment = 1
theme_override_constants/separation = 12

[node name="Result" type="Label" parent="Margin/VBox/ResultRow"]
layout_mode = 2
text = "Terminal result loads here."
vertical_alignment = 1
theme_override_colors/font_color = Color(0.55, 1, 0.65, 1)
theme_override_font_sizes/font_size = 16

[node name="Continue" type="Button" parent="Margin/VBox/ResultRow"]
custom_minimum_size = Vector2(130, 34)
layout_mode = 2
text = "Continue"

[node name="InputHint" type="Label" parent="Margin/VBox"]
layout_mode = 2
text = "Current battle bindings load here."
horizontal_alignment = 1
autowrap_mode = 2
theme_override_colors/font_color = Color(0.62, 1, 0.72, 1)
theme_override_font_sizes/font_size = 14
